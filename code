#include <DFRobot_RainfallSensor.h> // Library for the SEN0575 tipping-bucket rain gauge.
#include <ModbusMaster.h>           // Processes the RS485 Modbus packets from the solar meter.
#include <Notecard.h>               // Packages and transmits data through the Blues Notecard modem.
#include "wiring_private.h"         // Exposes pinPeripheral() so pins 10/11 can be remapped to a SERCOM UART.

// ---- 2. SETTINGS, HARDWARE ADDRESSES & TARGET FILE PATHS ----
#define productUID "com.gmail.kaplan5393:envirotech_mini_met_station" // Your unique Notehub cloud project identifier.
const uint8_t MUX_ADDR   = 0x70;           // Fixed I2C address of the DFRobot Gravity TCA9548A multiplexer.
const uint8_t SHT_CH     = 0;              // Multiplexer channel wired to the SHT31 temp/RH probe.
const uint8_t PRESS_CH   = 1;              // Multiplexer channel wired to the ICP10111 pressure sensor.
const uint8_t RAIN_CH    = 2;              // Multiplexer channel wired to the SEN0575 rain gauge.
const uint8_t SHT31_ADDR = 0x44;           // Fixed I2C address for the ambient air sensor (behind CH0).
const uint8_t PRESS_ADDR = 0x63;           // Fixed I2C address for the barometric pressure chip (behind CH1).
const uint8_t RAIN_ADDR  = 0x1D;           // Fixed I2C address for the rain gauge counter chip (behind CH2).
#define SD_CS_PIN 4                        // Specifies digital pin 4 as the hardware chip select controller line for the SD card reader.
static const size_t WAKE_PERIOD_S = 600;   // Sets a fixed 10-minute sleep duration (600 seconds) to maximize field battery preservation.

// ---- 3. RUNTIME HARDWARE OBJECTS ----
Adafruit_SHT31 sht31 = Adafruit_SHT31();            // Controls the SHT31 sensor interface.
DFRobot_ICP10111 icp;                               // Controls the barometric pressure chip.
DFRobot_RainfallSensor_I2C rainSensor(&Wire);       // Binds the rainfall sensor to the shared I2C bus.
ModbusMaster solarNode;                             // Modbus engine for the RS485 solar meter.
Notecard notecard;                                  // Master Notecard object for modem communications.

// ---- SOFTWARE-DEFINED UART FOR RS485 (moved off hardware Serial1 to free pins 0/1 for the Notecard) ----
Uart Serial2(&sercom1, 10, 11, SERCOM_RX_PAD_2, UART_TX_PAD_0); // Builds a second UART with RX on pin 10 and TX on pin 11 via SERCOM1.
void SERCOM1_Handler() { Serial2.IrqHandler(); }                // Routes SERCOM1 hardware interrupts into the new Serial2 receive engine.

// ---- 4. I2C MULTIPLEXER CHANNEL SELECT ----
void tcaSelect(uint8_t channel) {
  if (channel > 7) return;            // Guards against invalid channel requests beyond the multiplexer's 8 ports.
  Wire.beginTransmission(MUX_ADDR);   // Opens a transmission to the multiplexer's fixed control address.
  Wire.write(1 << channel);           // Writes a single set bit that opens only the requested downstream channel.
  Wire.endTransmission();             // Commits the channel-select command to the multiplexer.
  delay(10);                          // Gives the multiplexer's analog switches time to settle before the next transaction.
}

// ---- 5. LOW-LEVEL WIRE PROBE FUNCTION ----
bool probeI2CDevice(uint8_t channel, uint8_t address, const char* sensorName) {
  tcaSelect(channel);                 // Opens this sensor's dedicated multiplexer channel before probing it.
  Serial.print("Probing wires for "); // Sends diagnostic text to your computer screen to track validation progress.
  Serial.print(sensorName);           // Spits out the plain-text name of the module currently being queried on the traces.
  Serial.print(" [0x");               // Generates clean hexadecimal display brackets on your terminal window.
  Serial.print(address, HEX);         // Converts and displays the active device address into standard base-16 format.
  Serial.print("]... ");              // Cleans up trailing text rows to make incoming status labels readable.

  Wire.beginTransmission(address);    // Fires an empty test electron pulse down the data line looking for a response hook.
  uint8_t error = Wire.endTransmission(); // Collects the physical hardware numeric response status returned by the circuit tracks.

  if (error == 0) {                   // Checks if the response value equals zero, proving excellent electrical trace continuity.
    Serial.println("📡 Found response!"); // Informs the user that the target sensor is physically connected and responding.
    return true;                      // Returns true to signal that this sub-component is ready for data capture operations.
  } else {                            // Evaluates alternative action blocks if physical bus disruptions are identified.
    Serial.print("❌ MISSING! ");     // Prints an error symbol directly to your screen to flash a clear hardware alert notice.
    switch(error) {                   // Parses the raw numeric error byte returned by the chip to isolate the root connection failure.
      case 2: Serial.println("Reason: Sensor unplugged, missing power, or loose GND."); break; // Explains wire state 2.
      case 3: Serial.println("Reason: Sensor powered but rejected data. Loose wire."); break;   // Explains wire state 3.
      case 4: Serial.println("Reason: SDA/SCL lines are shorted or missing pull-ups."); break;  // Explains wire state 4.
      default: Serial.print("Reason: Unknown electrical error code "); Serial.println(error); break; // Catches anomalous responses.
    }
    return false;                     // Returns a false flag to protect the system from getting hung up on dead chips.
  }
}

void setup() {
  Serial.begin(115200); // Opens the primary diagnostic serial channel between the Feather board and your computer terminal window.
  delay(3000);          // Pauses processing actions for 3 seconds to let native USB interfaces settle after power restoration.

  Serial.println("\n================================================================="); // Draws an interface divider boundary line.
  Serial.println("🤖 WEATHER STATION SYSTEM WAKE - SENSOR & NOTECARD OVERHAUL"); // Prints the updated initialization sequence banner.
  Serial.println("================================================================="); // Draws an interface divider boundary line.

  Wire.begin(); // Spins up internal peripheral registers to establish the primary hardware I2C bus that reaches the multiplexer.

  // ---- INITIALIZE CELLULAR NOTECARD MODEM (I2C MODE) ----
  Serial.print("Initializing Blues Wireless Notecard... "); // Logs intent to register and communicate with the modem module.
  notecard.begin();                                         // Connects the processor to the Notecard over the I2C bus.
  notecard.setDebugOutputStream(Serial);                    // Routes internal modem transmission logs to print directly to your monitor screen.
  delay(50);                                                // Gives the link a moment to stabilize before the first command.
  Serial.println("✅ Online!");                             // Signals successful communication handshake with the cell module.

  // ---- CONFIGURE MODEM LOGIC & OUTBOUND ROUTING PATTERNS ----
  {
    J * req = notecard.newRequest("hub.set"); // Generates an empty JSON packet structured for the core Notehub configuration api.
    JAddStringToObject(req, "product", productUID); // Encapsulates your specific project cloud key inside the connection string.
    JAddStringToObject(req, "mode", "periodic"); // Programs the internal cellular radio to operate on energy-saving timed intervals.
    JAddNumberToObject(req, "outbound", 60); // Establishes your explicit 60-minute cloud data synchronization interval threshold.
    notecard.sendRequest(req); // Dispatches the completed settings command directly to the internal memory registers of the modem.
  }
  delay(50); // Lets the modem finish processing before the next command.

  // ---- OPTIMIZE CELLULAR POWER CHARGING VOLTAGES FOR LIPO CELLS ----
  {
    J * req = notecard.newRequest("card.voltage"); // Requests an instruction packet to adjust battery tracking definitions.
    JAddStringToObject(req, "mode", "lipo"); // Commands the modem to calibrate its safety sensors specifically for standard Lithium Polymer cells.
    notecard.sendRequest(req); // Commits the power-saving charging parameters directly to the modem motherboard storage layers.
  }
  delay(50); // Lets the modem finish processing before the next command.

  // ---- ESTABLISH MASTER DATA TEMPLATE FOR cellular OPTIMIZATION ----
  // NOTE: template values are Blues TYPE INDICATORS, not sample data:
  //   14 = 4-byte signed int | 12 = 2-byte signed int | 14.1 = 4-byte float
  {
    J * req = notecard.newRequest("note.template"); // Prepares an optimization template structure to drastically reduce cellular data usage costs.
    JAddStringToObject(req, "file", "weather.qo"); // Assigns the structural footprint filter specifically to your target weather files.
    J * body = JAddObjectToObject(req, "body"); // Allocates a permanent structured nested data container inside the configuration object.
    JAddNumberToObject(body, "time_ms", 14);     // Declares uptime as a 4-byte signed integer field.
    JAddNumberToObject(body, "sht31_t", 14.1);   // Declares air temperature as a 4-byte float field.
    JAddNumberToObject(body, "sht31_h", 14.1);   // Declares air humidity as a 4-byte float field.
    JAddNumberToObject(body, "icp101_t", 14.1);  // Declares die temperature as a 4-byte float field.
    JAddNumberToObject(body, "icp101_p", 14.1);  // Declares barometric pressure as a 4-byte float field.
    JAddNumberToObject(body, "rain_mm", 14.1);   // Declares rain accumulation as a 4-byte float field.
    JAddNumberToObject(body, "solar_w", 12);     // Declares solar irradiance as a 2-byte signed integer field.
    notecard.sendRequest(req); // Commits the schema matrix down to the modem so it can squeeze data arrays into raw bitwise blocks.
  }
  delay(50); // Lets the modem finish processing before the next command.

  // ---- INITIALIZE DETACHED ARRAYS & STARTUP CHECKS ----
  bool shtHardwareOK   = probeI2CDevice(SHT_CH, SHT31_ADDR, "SHT31 Temp/RH"); // Selects CH0 and wire-checks the air sensor.
  delay(20); // Brief settle time between successive multiplexer channel switches.
  bool pressHardwareOK = probeI2CDevice(PRESS_CH, PRESS_ADDR, "ICP10111 Pressure"); // Selects CH1 and wire-checks the pressure chip.
  delay(20); // Brief settle time between successive multiplexer channel switches.
  bool rainHardwareOK  = probeI2CDevice(RAIN_CH, RAIN_ADDR, "SEN0575 Rain Gauge"); // Selects CH2 and wire-checks the rain gauge.
  delay(20); // Brief settle time between successive multiplexer channel switches.
  bool sdHardwareOK    = SD.begin(SD_CS_PIN); // Checks if the SanDisk card is inserted and ready to accept raw data logs.

  // ---- VALIDATE AND LOAD MODULE SETTINGS ----
  if (shtHardwareOK)   { tcaSelect(SHT_CH);   sht31.begin(SHT31_ADDR); delay(20); } // Reselects CH0 before configuring the air module.
  if (pressHardwareOK) {
    tcaSelect(PRESS_CH);                 // Reselects CH1 before configuring the pressure module.
    icp.begin();                         // Initializes the ICP10111 driver.
    icp.setWorkPattern(icp.eUltraLowNoise); // Sets the high-resolution, low-noise measurement mode.
    icp.getTemperature();                // Throwaway priming read — discards the sensor's unreliable first conversion after mode config.
    icp.getAirPressure();                // Throwaway priming read — keeps the temp/pressure pair in sync before real data capture.
    delay(20);                           // Settling delay after priming, before moving to the next module.
  }
  if (rainHardwareOK)  { tcaSelect(RAIN_CH);  rainSensor.begin(); rainSensor.setRainAccumulatedValue(0.2794); delay(20); } // Reselects CH2 before configuring rain.

  Serial1.begin(4800);           // Opens the new UART on pins 10/11 to accept incoming signals from your solar reader.
