// ==================== SECTION: chart-building helpers ====================
function peakLabel(x,y,color,txt,dir){
  const dy = dir==='up' ? -7 : 15;
  return '<circle cx="'+x+'" cy="'+y+'" r="3" fill="none" stroke="'+color+'" stroke-width="1.5"/>'+
         '<text class="pklab" x="'+x+'" y="'+(y+dy)+'" fill="'+color+'">'+txt+'</text>';
}

// "Nice" axis step (1/2/5 * 10^n) so gridlines land on round numbers instead of
// arbitrary fractions -- the classic d3/matplotlib-style tick algorithm.
function niceStep(range, targetTicks){
  if(!(range>0)) return 1;
  const rough = range/targetTicks;
  const mag = Math.pow(10, Math.floor(Math.log10(rough)));
  const norm = rough/mag;
  const niceNorm = norm<1.5 ? 1 : norm<3 ? 2 : norm<7 ? 5 : 10;
  return niceNorm*mag;
}
function decimalsFor(step){
  const s = String(step);
  return s.indexOf('.')===-1 ? 0 : s.split('.')[1].length;
}

// ==================== SECTION: build one chart's SVG ====================
// Returns everything EXCEPT the descriptive title, which lives in HTML and is
// left out of exports so it can serve as the figure caption instead.
function buildSVG(cfg){
  const tMin=DATA[0].t, tMax=DATA[DATA.length-1].t;

  // pull each series' raw points -- either from our own DATA array, or (for
  // IMS reference series) from the IMS object under the given key
  const sp = cfg.series.map(s=>{
    const raw = s.points
      ? (IMS[s.points]||[])
      : DATA.map(d=>({t:d.t,v:d[s.key]}));
    // clip to the station's own time window so reference series (fetched with a
    // padding buffer) never draws past the left/right edge of the x-axis.
    const pts = raw.filter(p=>valid(p.v) && p.t>=tMin && p.t<=tMax);
    return {s, pts};
  });
  if(!sp.some(x=>x.pts.length)) return null;
  const multi = cfg.series.length>1;
  const W=840,H=470, m={l:78,r:22,t:(multi?42:20),b:80};

  // compute the data's min/max across all series on this chart
  let vals=[]; sp.forEach(x=>x.pts.forEach(p=>vals.push(p.v)));
  let dataMin=Math.min(...vals), dataMax=Math.max(...vals);
  if(dataMin===dataMax){ dataMin-=1; dataMax+=1; }

  // Nice, round-number axis bounds. Charts whose values are physically >=0
  // (solar irradiance, rainfall) are floored at exactly 0 -- never padded
  // into negative numbers -- while still getting a nicely-stepped top bound.
  let vMin, vMax, step;
  if(cfg.minZero){
    const topPad = dataMax*0.12 || 1;
    step = niceStep(dataMax+topPad, 5);
    vMin = 0;
    vMax = Math.max(step, Math.ceil((dataMax+topPad)/step)*step);
  } else {
    const pad=(dataMax-dataMin)*0.12;
    step = niceStep((dataMax+pad)-(dataMin-pad), 5);
    vMin = Math.floor((dataMin-pad)/step)*step;
    vMax = Math.ceil((dataMax+pad)/step)*step;
  }
  const decimals = decimalsFor(step);
  const X=t=> m.l + (tMax===tMin?0:(t-tMin)/(tMax-tMin))*(W-m.l-m.r);
  const Y=v=> m.t + (1-(v-vMin)/(vMax-vMin))*(H-m.t-m.b);
  const pB=H-m.b, pR=W-m.r;

  let s='<rect class="bg" x="0" y="0" width="'+W+'" height="'+H+'"/>';

  // -- horizontal gridlines, y-axis ticks and labels, at nice round-number steps --
  const nTicks = Math.round((vMax-vMin)/step);
  for(let i=0;i<=nTicks;i++){ const val=vMin+i*step, y=Y(val);
    s+='<line class="grid" x1="'+m.l+'" y1="'+y+'" x2="'+pR+'" y2="'+y+'"/>'+
       '<line class="tick" x1="'+(m.l-4)+'" y1="'+y+'" x2="'+m.l+'" y2="'+y+'"/>'+
       '<text class="tlab ytl" x="'+(m.l-8)+'" y="'+(y+3.5)+'">'+val.toFixed(decimals)+'</text>'; }

  // -- day separators (dashed vertical lines) + centered day labels --
  let bounds=[tMin]; let mid=localMidnight(tMin)+86400;
  while(mid<tMax){ bounds.push(mid); mid+=86400; } bounds.push(tMax);
  for(let i=1;i<bounds.length-1;i++){ const x=X(bounds[i]); s+='<line class="dayline" x1="'+x+'" y1="'+m.t+'" x2="'+x+'" y2="'+pB+'"/>'; }
  for(let i=0;i<bounds.length-1;i++){ const cx=X((bounds[i]+bounds[i+1])/2); s+='<text class="daylab" x="'+cx+'" y="'+(pB+52)+'">'+fmtDay((bounds[i]+bounds[i+1])/2)+'</text>'; }

  // -- 6-hour ticks + clock labels, so sunrise/noon/sundown are readable on the axis --
  let day=localMidnight(tMin);
  while(day<=tMax){ [6,12,18].forEach(h=>{ const tt=day+h*3600; if(tt>=tMin&&tt<=tMax){ const x=X(tt);
        s+='<line class="tick" x1="'+x+'" y1="'+pB+'" x2="'+x+'" y2="'+(pB+5)+'"/>'+
           '<text class="tlab xtl" x="'+x+'" y="'+(pB+18)+'">'+String(h).padStart(2,'0')+':00</text>'; } }); day+=86400; }

  // -- axis lines + rotated y-axis title + x-axis title --
  s+='<line class="axis" x1="'+m.l+'" y1="'+m.t+'" x2="'+m.l+'" y2="'+pB+'"/>'+
     '<line class="axis" x1="'+m.l+'" y1="'+pB+'" x2="'+pR+'" y2="'+pB+'"/>';
  const cy=(m.t+pB)/2;
  s+='<text class="axtitle" x="20" y="'+cy+'" transform="rotate(-90 20 '+cy+')">'+cfg.ylabel+'</text>';
  s+='<text class="axtitle" x="'+((m.l+pR)/2)+'" y="'+(H-8)+'">'+XAXIS_TITLE+'</text>';

  // -- data lines + latest-value dot + peak/valley time labels --
  function pathFor(pts){ let d=''; pts.forEach((p,i)=>{ d+=(i?'L':'M')+X(p.t).toFixed(1)+' '+Y(p.v).toFixed(1)+' '; }); return d; }
  function drawPeaks(x){
    if(x.s.noPeaks) return;
    const lv=x.pts[x.pts.length-1];
    s+='<circle cx="'+X(lv.t)+'" cy="'+Y(lv.v)+'" r="3.5" fill="'+x.s.color+'"/>';
    let pk=x.pts[0], vy=x.pts[0];
    x.pts.forEach(p=>{ if(p.v>pk.v)pk=p; if(p.v<vy.v)vy=p; });
    s+=peakLabel(X(pk.t),Y(pk.v),x.s.color,fmtHM(pk.t),'up');
    if(vy.t!==pk.t) s+=peakLabel(X(vy.t),Y(vy.v),x.s.color,fmtHM(vy.t),'down');
  }
  // solid own-sensor lines are drawn first (bottom layer)
  sp.filter(x=>x.pts.length && !x.s.dash).forEach(x=>{
    s+='<path d="'+pathFor(x.pts)+'" fill="none" stroke="'+x.s.color+'" stroke-width="2" stroke-linejoin="round"/>';
    drawPeaks(x);
  });
  // dashed IMS reference lines are drawn on top, each with a white halo stroke
  // underneath so the dashes stay visible even where they overlap a flat "0" line
  sp.filter(x=>x.pts.length && x.s.dash).forEach(x=>{
    const d=pathFor(x.pts);
    s+='<path d="'+d+'" fill="none" stroke="#ffffff" stroke-width="4.5" stroke-linejoin="round" stroke-dasharray="6 4"/>';
    s+='<path d="'+d+'" fill="none" stroke="'+x.s.color+'" stroke-width="2" stroke-linejoin="round" stroke-dasharray="6 4"/>';
    drawPeaks(x);
  });

  // -- legend, shown whenever more than one series actually has data, so the
  // color-to-source/location mapping is always spelled out, not just implied --
  const withData = sp.filter(x=>x.pts.length);
  if(withData.length>1){ let lx=m.l+4; const ly=22;
    withData.forEach(x=>{ const dashAttr=x.s.dash?' stroke-dasharray="6 4"':'';
      s+='<line x1="'+lx+'" y1="'+ly+'" x2="'+(lx+22)+'" y2="'+ly+'" stroke="'+x.s.color+'" stroke-width="2.5"'+dashAttr+'/>'+
        '<text class="leg" x="'+(lx+28)+'" y="'+(ly+4)+'">'+x.s.label+'</text>';
      lx += 36 + x.s.label.length*6.6; }); }
  return {inner:s, W, H, X, Y, sp, unit:cfg.unit, multi};
}

// ==================== SECTION: PNG export ====================
// Re-serializes the chart's SVG onto an off-screen canvas at 3x resolution (so
// exported figures are print-quality), then hands the resulting PNG blob to cb().
function toPNG(built, cb){
  const clean=document.createElementNS(SVGNS,'svg');
  clean.setAttribute('xmlns',SVGNS); clean.setAttribute('viewBox','0 0 '+built.W+' '+built.H);
  clean.setAttribute('width',built.W); clean.setAttribute('height',built.H);
  clean.innerHTML='<style>'+SVGCSS+'</style>'+built.inner;
  const data=new XMLSerializer().serializeToString(clean);
  const img=new Image();
  img.onload=()=>{ const sc=3, cv=document.createElement('canvas'); cv.width=built.W*sc; cv.height=built.H*sc;
    const ctx=cv.getContext('2d'); ctx.fillStyle='#fff'; ctx.fillRect(0,0,cv.width,cv.height);
    ctx.setTransform(sc,0,0,sc,0,0); ctx.drawImage(img,0,0); cv.toBlob(cb,'image/png'); };
  img.onerror=()=>{ toast('Render failed'); };
  img.src='data:image/svg+xml;charset=utf-8,'+encodeURIComponent(data);
}

// ==================== SECTION: assemble one chart "card" ====================
// title + Copy/PNG buttons + current-value line + the SVG itself + a hover
// tooltip that snaps to the nearest data point across all series on the chart.
function makeChart(cfg){
  const card=document.createElement('div'); card.className='card';
  const head=document.createElement('div'); head.className='head';
  head.innerHTML='<h3>'+cfg.title+'</h3>';
  const built=buildSVG(cfg);
  if(!built){ card.appendChild(head); card.insertAdjacentHTML('beforeend','<div class="empty">No data</div>'); return card; }

  const btns=document.createElement('div'); btns.className='btns';
  const bCopy=document.createElement('button'); bCopy.textContent='Copy';
  const bPng=document.createElement('button'); bPng.textContent='PNG';
  btns.appendChild(bCopy); btns.appendChild(bPng); head.appendChild(btns);
  card.appendChild(head);

  // "current value" line under the title, one entry per series that has data
  let cur='';
  built.sp.forEach(x=>{ if(x.pts.length){ const lv=x.pts[x.pts.length-1];
    cur += '<span style="color:'+x.s.color+'">●</span> '+(built.multi?x.s.label+': ':'')+'<b>'+lv.v.toFixed(2)+' '+cfg.unit+'</b>&nbsp;&nbsp;'; } });
  card.insertAdjacentHTML('beforeend','<div class="cur">'+cur+'</div>');

  const svg=document.createElementNS(SVGNS,'svg');
  svg.setAttribute('viewBox','0 0 '+built.W+' '+built.H);
  svg.innerHTML='<style>'+SVGCSS+'</style>'+built.inner;
  const {X,Y}=built;
  // flatten every series' points into one array so hover can find the closest
  // point across ALL lines on the chart, not just one series
  const all=[]; built.sp.forEach(x=>x.pts.forEach(p=>all.push({t:p.t,v:p.v,label:x.s.label,color:x.s.color})));
  const dot=document.createElementNS(SVGNS,'circle');
  dot.setAttribute('r','4'); dot.setAttribute('fill','none'); dot.setAttribute('stroke-width','2'); dot.style.display='none'; svg.appendChild(dot);
  svg.addEventListener('mousemove',ev=>{
    const r=svg.getBoundingClientRect(); const sx=(ev.clientX-r.left)/r.width*built.W;
    let near=all[0], best=1e18;
    for(const p of all){ const dd=Math.abs(X(p.t)-sx); if(dd<best){best=dd; near=p;} }
    dot.style.display='block'; dot.setAttribute('cx',X(near.t)); dot.setAttribute('cy',Y(near.v)); dot.setAttribute('stroke',near.color);
    tip.style.display='block'; tip.style.left=(ev.clientX+14)+'px'; tip.style.top=(ev.clientY+14)+'px';
    tip.innerHTML='<b>'+near.v.toFixed(2)+' '+built.unit+'</b><br>'+(built.multi?near.label+'<br>':'')+fmtFull(near.t);
  });
  svg.addEventListener('mouseleave',()=>{ dot.style.display='none'; tip.style.display='none'; });
  card.appendChild(svg);

  // PNG button downloads the export as "<slug>.png"
  bPng.addEventListener('click',()=>toPNG(built,b=>{ if(!b){toast('Export failed');return;}
    const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download=cfg.slug+'.png'; a.click(); toast('Downloaded '+cfg.slug+'.png'); }));
  // Copy button puts the export directly on the clipboard as an image
  bCopy.addEventListener('click',()=>toPNG(built,async b=>{ try{
    await navigator.clipboard.write([new ClipboardItem({'image/png':b})]); toast('Copied to clipboard'); }
    catch(e){ toast('Copy blocked here — use PNG download'); } }));
  return card;
}

// ==================== SECTION: build every chart card ====================
if(META.count>0){
  const wrap=document.getElementById('charts');
  CHARTS.forEach(c=> wrap.appendChild(makeChart(c)));
}

