#!/usr/bin/env python3
"""
Envirotech Mini Met Station -- local live dashboard generator
=============================================================
Pulls weather.qo events from your Blues Notehub project and writes a single
self-contained dashboard.html (charts + latest readings). Re-run any time to
refresh with the newest data.

SETUP (one time):
  1. Create a Notehub Personal Access Token:
       Notehub -> account menu (top-right) -> Settings -> Personal Access Tokens
       -> create one, copy it.
  2. Create notehub_secret.txt beside this script (git-ignored) with:
       NOTEHUB_TOKEN=your_token
       NOTEHUB_PROJECT_UID=com.your-namespace:your_project
       IMS_TOKEN=your_ims_token   (optional, enables the IMS reference overlay)

RUN:
  python3 station_dashboard.py
  -> writes dashboard.html and opens it in your browser.

No external libraries needed -- Python 3 standard library only.
"""

import json
import os
import sys
import urllib.request
import urllib.parse
import urllib.error
import webbrowser
from datetime import datetime, timezone, timedelta


# =============================== SECRETS LOADER ==================================
# Reads tokens/UIDs from environment variables first, then falls back to a
# git-ignored notehub_secret.txt (KEY=value lines) sitting next to this script.
# Nothing identifying ever lives in this .py file, so it's safe to commit to GitHub.
_SECRET_CACHE = None


def _secret(key, default=""):
    """Read a value from env var KEY, else from the untracked notehub_secret.txt (KEY=value lines)."""
    v = os.environ.get(key, "").strip()
    if v:
        return v
    global _SECRET_CACHE
    if _SECRET_CACHE is None:
        _SECRET_CACHE = {}
        path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "notehub_secret.txt")
        if os.path.exists(path):
            with open(path, encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    k, _, val = line.partition("=")   # partition on first "=" (token contains "=")
                    _SECRET_CACHE[k.strip()] = val.strip()
    return _SECRET_CACHE.get(key, default)


# =============================== CONFIG -- EDIT THESE =============================
PROJECT_UID  = _secret("NOTEHUB_PROJECT_UID")
TOKEN        = _secret("NOTEHUB_TOKEN")
NOTEFILE     = "weather.qo"     # which Notefile to chart
MAX_EVENTS   = 1000             # how many of the most recent readings to pull
START_LOCAL  = "2026-07-13 13:25"  # only include readings at/after this local time; "" = all
OUT_PATH     = "dashboard.html" # output file (written next to this script)
OPEN_BROWSER = True             # auto-open the dashboard after generating
# ===================================================================================

# Metrics that are 0 (not missing) when absent: dry rain gauge / dark solar sensor.
ZERO_FILL = ("rain_mm", "solar_w")

BASE = "https://api.notefile.net"
PAGE_SIZE = 100

METRIC_KEYS = ["sht31_t", "sht31_h", "icp101_t", "icp101_p", "rain_mm", "solar_w"]

# =============================== IMS REFERENCE DATA (optional) ====================
# Overlays Israel Meteorological Service data for the same period, for comparison.
# Token from notehub_secret.txt / env var IMS_TOKEN (request one at ims@ims.gov.il,
# see https://ims.gov.il/en/ObservationDataAPI). If absent, the overlay is skipped.
IMS_TOKEN = _secret("IMS_TOKEN")
IMS_BASE = "https://api.ims.gov.il/v1/envista"

# IMS's own API docs state observation timestamps are always Israel STANDARD time
# (UTC+2) year-round, even though the API mislabels them "+03:00" in summer -- so
# that suffix must be stripped and replaced with the real +02:00 offset, or every
# point lands an hour off from the station's true UTC-synced Notecard timestamps.
IMS_TZ = timezone(timedelta(hours=2))

# Sde Boker has no solar-radiation or pressure sensor; Ashalim (~15 km away) is the
# nearest active IMS station with both, at the same 10-minute resolution.
IMS_STATIONS = {
    "sde_boker": {"id": 98, "channels": {"td": 7, "rh": 8, "rain": 1}},
    "ashalim":   {"id": 381, "channels": {"grad": 14, "bp": 18}},
}


def fetch_ims_channel(station_id, channel_id, date_from, date_to):
    """Pull one IMS channel over a date range. Returns [(epoch_utc, value), ...]."""
    url = f"{IMS_BASE}/stations/{station_id}/data/{channel_id}?from={date_from}&to={date_to}"
    req = urllib.request.Request(url, headers={"Authorization": f"ApiToken {IMS_TOKEN}"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            payload = json.load(resp)
    except (urllib.error.HTTPError, urllib.error.URLError) as e:
        print(f"  WARNING: IMS fetch failed (station {station_id}, channel {channel_id}): {e}")
        return []
    out = []
    for row in payload.get("data", []):
        try:
            naive = datetime.strptime(row.get("datetime", "")[:19], "%Y-%m-%dT%H:%M:%S")
        except ValueError:
            continue
        epoch = naive.replace(tzinfo=IMS_TZ).timestamp()  # corrected UTC+2, not the mislabeled +03:00
        for ch in row.get("channels", []):
            if ch.get("id") == channel_id and ch.get("valid") and ch.get("value") is not None:
                out.append((epoch, ch["value"]))
    return out


def fetch_ims_all(rows):
    """Fetch IMS reference series spanning the same period as `rows`. None if no token/data."""
    if not IMS_TOKEN or not rows:
        return None
    first_local = datetime.fromtimestamp(rows[0]["t"]).astimezone()
    last_local = datetime.fromtimestamp(rows[-1]["t"]).astimezone()
    date_from = (first_local - timedelta(days=1)).strftime("%Y/%m/%d")  # 1-day pad absorbs
    date_to = (last_local + timedelta(days=1)).strftime("%Y/%m/%d")     # the tz correction at day edges

    print(f"Fetching IMS reference data ({date_from} to {date_to}) ...")
    series = {}
    for station_key, cfg in IMS_STATIONS.items():
        for chan_key, chan_id in cfg["channels"].items():
            pts = fetch_ims_channel(cfg["id"], chan_id, date_from, date_to)
            series[f"{station_key}_{chan_key}"] = [{"t": t, "v": v} for t, v in pts]

    # IMS "Rain" is rainfall accumulated per 10-minute interval, not a running total;
    # sum it into a cumulative series to compare against the gauge's cumulative reading.
    total, cum = 0.0, []
    for p in sorted(series.get("sde_boker_rain", []), key=lambda p: p["t"]):
        total += p["v"]
        cum.append({"t": p["t"], "v": round(total, 3)})
    series["sde_boker_rain_cum"] = cum

    print(f"Got {sum(len(v) for v in series.values())} IMS reference points.")
    return series


# =============================== NOTEHUB FETCH =====================================
def fetch_events():
    """Pull the most recent events for NOTEFILE, newest first, across pages."""
    collected = []
    page = 1
    while len(collected) < MAX_EVENTS:
        query = urllib.parse.urlencode({
            "pageSize": PAGE_SIZE,
            "pageNum": page,
            "sortBy": "captured",
            "sortOrder": "desc",   # newest first
            "files": NOTEFILE,
        })
        url = f"{BASE}/v1/projects/{PROJECT_UID}/events?{query}"
        req = urllib.request.Request(url, headers={"Authorization": f"Bearer {TOKEN}"})
        try:
            with urllib.request.urlopen(req, timeout=30) as resp:
                payload = json.load(resp)
        except urllib.error.HTTPError as e:
            body = e.read().decode(errors="replace")
            print(f"ERROR: HTTP {e.code} from Notehub.\n{body}")
            if e.code in (401, 403):
                print("\nCheck that your TOKEN is valid and PROJECT_UID is correct.")
            sys.exit(1)
        except urllib.error.URLError as e:
            print(f"ERROR: could not reach Notehub ({e.reason}). Check your internet.")
            sys.exit(1)

        batch = payload.get("events", payload if isinstance(payload, list) else [])
        if not batch:
            break
        collected.extend(batch)
        if len(batch) < PAGE_SIZE:
            break
        page += 1

    return collected[:MAX_EVENTS]


def start_epoch():
    """Convert START_LOCAL (interpreted in the computer's local timezone) to epoch seconds."""
    if not START_LOCAL:
        return None
    dt = datetime.strptime(START_LOCAL, "%Y-%m-%d %H:%M").astimezone()
    return dt.timestamp()


def to_rows(events):
    """Flatten events into chart rows, oldest -> newest, dropping empty bodies."""
    cutoff = start_epoch()
    rows = []
    for e in events:
        when = e.get("when")
        body = e.get("body") or {}
        if when is None:
            continue
        if cutoff is not None and when < cutoff:
            continue  # before the requested start time
        vals = {k: body.get(k) for k in METRIC_KEYS}
        if all(v is None for v in vals.values()):
            continue  # skip the empty "{}" notes
        for k in ZERO_FILL:          # a real reading with no rain/solar means 0, not missing
            if vals[k] is None:
                vals[k] = 0
        row = {"t": when}
        row.update(vals)
        rows.append(row)
    rows.sort(key=lambda r: r["t"])   # chronological for plotting (by capture time)
    return rows


# =============================== HTML/JS TEMPLATE ==================================
def build_html(rows, ims_series=None):
    meta = {
        "station": "Envirotech Mini Met Station",
        "generated": datetime.now().astimezone().strftime("%Y-%m-%d %H:%M"),
        "count": len(rows),
        "first": rows[0]["t"] if rows else None,
        "last": rows[-1]["t"] if rows else None,
    }
    return (TEMPLATE
            .replace("__DATA__", json.dumps(rows))
            .replace("__META__", json.dumps(meta))
            .replace("__IMS__", json.dumps(ims_series or {})))


